{
    "manifest_version": 2,
    "name": "Magi Magi",
    "version": "1.0",

    "description": "Captura texto selecionado e envia para o servidor Flask.",

    "icons": {
        "48": "icon.png"
    },

    "permissions": [
        "activeTab",
        "contextMenus",
        "storage"
    ],

    "background": {
        "scripts": ["background.js"]
    },

    "browser_action": {
        "default_icon": "icon.png",
        "default_popup": "popup.html",
        "default_title": "Magi Magi"
    },

    "content_scripts": [
        {
            "matches": ["<all_urls>"],
            "js": ["content.js"],
            "run_at": "document_end"
        }
    ]
}
